{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "vitest", "node", "promise"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "env": {
    "builtin": true,
    "node": true,
    "vitest": true
  },
  "ignorePatterns": [
    "dist/**",
    "coverage/**",
    "node_modules/**",
    ".pnpm-store/**",
    "docs/.vitepress/.temp/**",
    "docs/.vitepress/cache/**",
    "docs/.vitepress/dist/**"
  ],
  "rules": {
    "eslint/no-useless-escape": "off",
    "unicorn/no-useless-spread": "off",
    "vitest/require-to-throw-message": "off"
  }
}
